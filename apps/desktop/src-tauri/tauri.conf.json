{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RouteBox",
  "version": "0.1.0",
  "identifier": "com.routebox.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "RouteBox",
        "width": 360,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:* wss://localhost:* http://localhost:* https://api.routebox.dev wss://api.routebox.dev; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "API traffic monitor for developers",
    "longDescription": "RouteBox is a macOS menu bar app that provides real-time API traffic monitoring, routing strategy management, and cost tracking for developers.",
    "copyright": "Copyright (c) 2025 RouteBox",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    }
  },
  "plugins": {}
}
