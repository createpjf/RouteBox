# RouteBox Gateway — Environment Variables
# Copy to .env and fill in your API keys

# Provider API keys (add the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
KIMI_API_KEY=
FLOCK_API_KEY=

# Optional: custom base URLs (defaults shown)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# FLOCK_BASE_URL=https://api.flock.io/v1

# Database path (Docker deployments)
# ROUTEBOX_DB_PATH=/data/routebox.db
