{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["bun"],
    "paths": {
      "@gateway/*": ["../gateway/src/*"]
    }
  },
  "include": ["src"]
}
